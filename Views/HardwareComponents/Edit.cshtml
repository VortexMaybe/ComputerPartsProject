@model ComputerParts.Models.HardwareComponent

@{
    ViewData["Title"] = "Редактиране";
}

<div class="container mt-4 animate__animated animate__fadeInUp">
    <h2 class="text-primary"><i class="bi bi-pencil-square"></i> Редактиране на компонент</h2>
    <hr />
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card bg-dark text-white shadow-lg border-secondary rounded-4">
                <div class="card-header border-secondary bg-transparent p-4">
                    <h2 class="mb-0 text-primary fw-bold text-center">
                        <i class="bi bi-pencil-square me-2"></i>Редактиране на компонент
                    </h2>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ImageUrl" />

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold text-secondary text-uppercase small">Име на компонента</label>
                            <div class="input-group">
                                <span class="input-group-text bg-secondary border-secondary text-white"><i class="bi bi-cpu"></i></span>
                                <input asp-for="Name" class="form-control bg-dark text-white border-secondary shadow-none" placeholder="напр. NVIDIA RTX 4090" />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Manufacturer" class="form-label fw-bold text-secondary text-uppercase small">Производител</label>
                                <input asp-for="Manufacturer" class="form-control bg-dark text-white border-secondary shadow-none" placeholder="напр. ASUS" />
                                <span asp-validation-for="Manufacturer" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="Type" class="form-label fw-bold text-secondary text-uppercase small">Категория</label>
                                <select asp-for="Type" class="form-select bg-dark text-white border-secondary shadow-none">
                                    <option value="ПРОЦЕСОР">Процесор</option>
                                    <option value="ВИДЕОКАРТА">Видеокарта</option>
                                    <option value="RAM">RAM памет</option>
                                    <option value="SSD">SSD диск</option>
                                    <option value="HDD">HDD диск</option>
                                </select>
                                <span asp-validation-for="Type" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Price" class="form-label fw-bold text-secondary text-uppercase small">Цена (€)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-success border-success text-white">€</span>
                                <input asp-for="Price" class="form-control bg-dark text-white border-secondary shadow-none" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 mt-5">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill shadow">
                                <i class="bi bi-save me-2"></i>Запази промените
                            </button>
                            <a asp-action="Index" class="btn btn-outline-light rounded-pill border-0 mt-2">
                                <i class="bi bi-arrow-left me-2"></i>Отказ и връщане
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <p class="text-center mt-4 text-secondary small">ID на компонента: @Model.Id</p>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}