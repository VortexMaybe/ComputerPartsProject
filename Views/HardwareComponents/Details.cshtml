@model ComputerParts.Models.HardwareComponent

@{
    ViewData["Title"] = "Детайли";
}

<div class="container mt-5 animate__animated animate__zoomIn">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card bg-dark text-white shadow-lg border-secondary rounded-4 overflow-hidden">
                <div class="row g-0">

                    <div class="col-md-7 p-5">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb mb-4">
                                <li class="breadcrumb-item"><a asp-action="Index" class="text-secondary text-decoration-none small text-uppercase fw-bold">Компоненти</a></li>
                                <li class="breadcrumb-item active text-primary small text-uppercase fw-bold" aria-current="page">@Model.Type</li>
                            </ol>
                        </nav>

                        <h1 class="display-5 fw-bold mb-3">@Model.Name</h1>
                        <p class="h4 text-secondary mb-4">Производител: <span class="text-light">@Model.Manufacturer</span></p>

                        <div class="d-flex align-items-center mb-5">
                            <div class="h2 text-success fw-bold mb-0 me-3">@Model.Price.ToString("F2") €</div>
                            <span class="badge bg-primary px-3 py-2 rounded-pill">В наличност</span>
                        </div>

                        <div class="p-4 rounded-3 border border-secondary bg-black bg-opacity-25 mb-5">
                            <h5 class="text-primary fw-bold mb-3"><i class="bi bi-card-list me-2"></i>Спецификации</h5>
                            <ul class="list-unstyled mb-0">
                                <li class="mb-2"><i class="bi bi-patch-check text-success me-2"></i> 24 месеца официална гаранция</li>
                                <li class="mb-2"><i class="bi bi-box-seam text-success me-2"></i> Оригинална опаковка</li>
                                <li><i class="bi bi-truck text-success me-2"></i> Безплатна доставка до 24 часа</li>
                            </ul>
                        </div>

                        <div class="d-flex gap-3">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-lg px-4 rounded-pill shadow">
                                <i class="bi bi-pencil-fill me-2"></i>Редактирай
                            </a>
                            <a asp-action="Index" class="btn btn-outline-light btn-lg px-4 rounded-pill">
                                <i class="bi bi-arrow-left me-2"></i>Назад
                            </a>
                        </div>
                    </div>

                    <div class="col-md-5 bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center p-4 border-start border-secondary">
                        <div class="text-center">
                            <img src="@Model.ImageUrl"
                                 class="img-fluid rounded-4 shadow-lg bg-dark p-2"
                                 style="max-height: 400px; object-fit: contain; border: 1px solid #444;"
                                 alt="@Model.Name">
                            <p class="text-secondary mt-3 small italic">Изображението е примерно</p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>